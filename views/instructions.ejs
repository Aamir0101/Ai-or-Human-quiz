<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Instructions — Human or AI?</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <canvas id="starfield"></canvas>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="scan-grid"></div>

  <main class="page">
    <div class="instr-card">

      <h1 class="instr-heading">
        How to <span class="hl">Play</span>
      </h1>
      <div class="accent-line" style="margin: 1rem 0;"></div>

      <ul class="instr-steps">
        <li>
          <div class="step-num">1</div>
          <div>You'll be shown <strong>10 images</strong>, one at a time.</div>
        </li>
        <li>
          <div class="step-num">2</div>
          <div>For each image, decide: was it created by a <strong>human artist</strong> or generated by <strong>AI</strong>?</div>
        </li>
        <li>
          <div class="step-num">3</div>
          <div>Tap <strong>"Human"</strong> or <strong>"AI"</strong>. You'll get instant feedback — green means correct, red means wrong.</div>
        </li>
        <li>
          <div class="step-num">4</div>
          <div>The quiz advances automatically. No time pressure — <strong>take your time</strong> and study each image carefully.</div>
        </li>
        <li>
          <div class="step-num">5</div>
          <div>At the end, you'll see your <strong>final score</strong>. Can you get a perfect 10?</div>
        </li>
      </ul>

      <div class="instr-cta">
        <a href="/quiz" class="btn btn-primary">Start Quiz &rarr;</a>
        <a href="/" class="btn btn-back">&larr; Back</a>
      </div>

    </div>
  </main>

  <script>
    /* ── Starfield (shared) ── */
    (function () {
      const canvas = document.getElementById('starfield');
      const ctx    = canvas.getContext('2d');
      let stars    = [];
      const COUNT  = 100;
      function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
      function init()   { stars = Array.from({ length: COUNT }, () => ({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, r: Math.random() * 1.2 + 0.2, speed: Math.random() * 0.005 + 0.001, phase: Math.random() * Math.PI * 2 })); }
      function draw()   { ctx.clearRect(0, 0, canvas.width, canvas.height); const t = Date.now() * 0.001; stars.forEach(s => { const a = 0.15 + 0.65 * (0.5 + 0.5 * Math.sin(t * s.speed * 60 + s.phase)); ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2); ctx.fillStyle = `rgba(232,234,240,${a})`; ctx.fill(); }); requestAnimationFrame(draw); }
      resize(); init(); draw();
      window.addEventListener('resize', () => { resize(); init(); });
    })();
  </script>

</body>
</html>
